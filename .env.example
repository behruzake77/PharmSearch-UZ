# Backend Configuration
# SESSION_SECRET: JWT token signing secret (generate with: python -c "import secrets; print(secrets.token_urlsafe(32))")
SESSION_SECRET=your-secret-key-here-change-this-in-production

# Optional: Google Custom Search API
# Leave blank to disable Google search fallback
GOOGLE_API_KEY=
GOOGLE_CSE_ID=

# Optional: Database URL (default is SQLite)
# DATABASE_URL=sqlite:///pharmacy.db
# For PostgreSQL: DATABASE_URL=postgresql://user:password@localhost/pharmacy
